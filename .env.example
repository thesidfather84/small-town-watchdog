# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string — Neon production database
# Get this from: https://console.neon.tech → your project → Connection Details
# Host must be: ep-falling-bar-aj4xg2tq.c-3.us-east-2.aws.neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@ep-falling-bar-aj4xg2tq.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Optional — AI Summaries ─────────────────────────────────────────────────

# OpenAI API key for generating plain-English summaries
OPENAI_API_KEY=sk-...

# If using a proxy / custom OpenAI-compatible endpoint:
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ─── Local dev only (not needed on Vercel) ────────────────────────────────────

# Port for the local API server (Vercel manages this automatically)
PORT=3000

# Port for the local Vite dev server (Vercel manages this automatically)
# VITE_PORT=5173

# Base URL path for the frontend (default "/" — leave blank for Vercel)
# BASE_PATH=/

# URL of the API server for Vite dev proxy
# API_URL=http://localhost:3000

# Log level for the API server (default: info)
# LOG_LEVEL=info
